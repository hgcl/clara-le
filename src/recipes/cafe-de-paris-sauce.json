  "instructions": [
    {
      "insTitle": "",
      "insSteps": [
        "In a bowl, using a wooden spatula, soften the butter to a spreadable consistency for a few minutes.",
        "Press the garlic cloves, and mix them with the butter.",
        "In a food processor or by hand, finely chop all the herbs (including the parsley). Add all the herbs to the butter.",
        "Add the soy sauce, lemon juice, cognac, curry powder, and mustard. Season with pepper. Mix well with the spatula. Taste and adjust the seasoning with salt if necessary.",
        "Refrigerate for at least 1 hour."
      ]
    }
