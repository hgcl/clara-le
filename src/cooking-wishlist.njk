---
title: Cooking wishlist
description: Recipes I want to
icon: /public/img/meta/drawing-list.svg
pagination:
    data: "cookingWishlistData"
    size: 1
---

{% from 'macro/list-filter-selector.njk' import listFilterSelector %}
{% extends "layout/base.njk" %} 

{% block head %}
<style>
  .intro { 
    margin-bottom: 3rem;
  }
  #random-link {
    margin: 0 auto;
    display: block;
  }
</style>
{% endblock %}

{% block article %}
<article class="center h-entry">
  <div class="e-content">
  {% include 'post-header.njk' %}
    <p class="intro">
      My forever growing list of recipes I want to try
    </p>

    <!-- POST FILTER SELECTOR -->
    {{ listFilterSelector('category', ['Main','Dessert','Basic','Snack','Drink','Preserve']) }}

    <!-- LINK LIST -->
      <ul
        class="nobullet post-rows-with-label filtered-list">
        {% for item in pagination.pages | reverse %}
          <li data-tag="{{ item.tags }}">
            <time class="label dt-duration" datetime="{{ item.date }}">{{ item.date | formatDate("short") }}</time>
            <span class="details">
              <a href="{{ item.url }}">{{ item.title }}</a>
              <span class="subtle">Found on {{ item.domain }}</span>
                {% set divider = joiner(" / ") %}
                {% if item.tags %}
                {%- for tag in item.tags -%}
                  {{ divider() }}<a class="chip" href="/cooking-wishlist/?q={{ tag }}">{{ tag }}</a>
                {%- endfor -%}
                {% endif %}
            </span>
          </li>
        {% endfor %}
      </ul>
  </div>
</article>
{% endblock %}

{% block script %}
  {% include 'filter-notes-script.njk' %}
{% endblock %}